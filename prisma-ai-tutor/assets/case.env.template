# PUBMED_MAX_RETRIES=3
# PUBMED_RETRY_DELAY=1
# PUBMED_MAX_RETRY_WAIT=30


# =========================
# INTEGRACIONES FUTURAS
# =========================

# Configuración base para la futura integración con Zotero.
# Estos parámetros no los usa openalex_search.py, pero sí deben vivir
# en el mismo archivo .env para centralizar la configuración operativa
# del caso o de la ejecución.

# Nombre de la librería de Zotero.
# Ejemplo real acordado:
# ZOTERO_LIBRARY=Mi biblioteca
ZOTERO_LIBRARY=

# Override opcional del endpoint MCP de Zotero.
# Normalmente conviene dejarlo en `base.env`.
# ZOTERO_MCP_URL=http://127.0.0.1:23120/mcp

# Ruta jerárquica de la colección destino dentro de la librería.
# Ejemplo real acordado:
# ZOTERO_COLLECTION=UTE CLASES/PRUEBA-IA
ZOTERO_COLLECTION=

# Carpeta local donde están los PDFs que se intentarán adjuntar a Zotero.
# Ejemplo:
# ZOTERO_ATTACHMENTS_DIR=outputs/mi-corrida/fulltext
ZOTERO_ATTACHMENTS_DIR=

# Carpeta que Zotero usa como base para almacenar o enlazar los PDFs.
# Aquí se copiarán los documentos antes de asociarlos a los ítems.
# Ejemplo:
# ZOTERO_LIBRARY_FILES_DIR=/home/usuario/Zotero/storage-import
ZOTERO_LIBRARY_FILES_DIR=

# Ruta al artefacto de decisiones finales confirmado por el estudiante.
# Este archivo será la fuente de verdad para decidir qué entra a Zotero.
# Ejemplo:
# ZOTERO_SCREENING_DECISIONS=outputs/openalex-search-v2/screening/screening_decisions_final.csv
ZOTERO_SCREENING_DECISIONS=

# Ruta a la matriz de cribado usada para complementar metadata y URLs.
# Ejemplo:
# ZOTERO_SCREENING_MATRIX=outputs/openalex-search-v2/screening/screening_matrix.csv
ZOTERO_SCREENING_MATRIX=
