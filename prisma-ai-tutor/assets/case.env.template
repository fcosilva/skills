# outputs/<corrida>/search/pubmed/
# y deja la matriz común en:
# outputs/<corrida>/screening/
# Si este caso usa Fase 3 multi-fuente, iguala este valor con OPENALEX_OUT_DIR.
PUBMED_OUT_DIR=outputs/pubmed-search

