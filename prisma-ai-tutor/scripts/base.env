# Configuracion base reutilizable para PRISMA-AI Tutor
#
# Este archivo es una copia local de conveniencia, no la ubicacion canonica
# recomendada para una configuracion portable del skill.
# La recomendacion actual es ubicar el base.env real fuera del skill, por ejemplo:
# - config/prisma-ai-tutor/base.env
# - ~/.codex/prisma-ai-tutor/base.env
#
# Si el skill vive fuera del workspace, el case.env puede fijar ademas:
# PRISMA_AI_TUTOR_WORKSPACE_ROOT=../..

OPENALEX_API_KEY=KZxyOvJnI8an7aPLEIZwyd
OPENALEX_MAILTO=josef.silva@ute.edu.ec

OPENALEX_SEARCH_MODE=title_abstract
OPENALEX_NO_STEM=false

OPENALEX_MAX_RESULTS=150
OPENALEX_PER_PAGE=50
OPENALEX_MAX_RETRIES=4
OPENALEX_RETRY_DELAY=2
OPENALEX_MAX_RETRY_WAIT=60
PRISMA_PROGRESS_DOWNLOAD_EVERY=10

OPENALEX_QUERY_OUTPUT_NAME=query.txt

ZOTERO_LIBRARY=Mi biblioteca
ZOTERO_MCP_URL=http://127.0.0.1:23120/mcp
ZOTERO_COLLECTION=UTE CLASES/INV/PRUEBA-IA
